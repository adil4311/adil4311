# Core
APP_ENV=development
SECRET_KEY=change_this_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite+aiosqlite:///./hyperai.db
# For Postgres in production, e.g.:
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/hyperai

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Encryption (Fernet 32-byte urlsafe base64 key)
ENCRYPTION_KEY=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]