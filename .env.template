# HyperAI Builder Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=HyperAI Builder
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database Configuration
DATABASE_URL=sqlite:///./hyperai_builder.db
# For PostgreSQL: postgresql://username:password@localhost:5432/hyperai_builder
# For MySQL: mysql://username:password@localhost:3306/hyperai_builder

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security Configuration
SECRET_KEY=your-super-secret-key-here-make-it-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Model API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# AI Model Configuration
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4000
TEMPERATURE=0.7
REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_REQUESTS=10

# UI Configuration
THEME=dark
PRIMARY_COLOR=#6366f1
ACCENT_COLOR=#8b5cf6
FONT_FAMILY=Roboto, sans-serif
ENABLE_ANIMATIONS=true
ANIMATION_DURATION=0.3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development Settings
PYTHONPATH=.
PYTHONUNBUFFERED=1